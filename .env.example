# ─── Application ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Zerodha Kite Connect ──────────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# ─── Zerodha Auto-Login ────────────────────────────────
ZERODHA_USER_ID=youruserid
ZERODHA_PASSWORD=yourpassword
ZERODHA_TOTP_SECRET=yoursecretkey   # from Zerodha 2FA setup

# ─── AngelOne Smart API (fallback) ─────────────────────
ANGEL_API_KEY=your_angel_api_key
ANGEL_CLIENT_ID=your_angel_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_angel_totp_secret

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://alpha8:alpha8_dev@localhost:5432/alpha8

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Telegram Notifications ───────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Trading Configuration ────────────────────────────
TRADING_CAPITAL=100000
LIVE_TRADING=false
MAX_DAILY_LOSS_PCT=2
MAX_POSITION_COUNT=5
PER_TRADE_STOP_LOSS_PCT=1
KILL_SWITCH_DRAWDOWN_PCT=5

# ─── Watchlist ─────────────────────────────────────────
WATCHLIST=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK

# ─── API Authentication ───────────────────────────────
# Set a secret key to protect API endpoints (killswitch, settings)
# Leave empty for development (open access)
API_SECRET_KEY=

# ─── Token Encryption ─────────────────────────────────
# 64-character hex string (32 bytes) used to encrypt the broker access token in Redis.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ─── News Sentiment Filter (Gemini API) ───────────────
# Powers the news sentiment gate in the signal pipeline.
# Get your key at: https://aistudio.google.com/
# Leave empty to disable news filtering (other 3 gates still active).
# Cost: Free or very low cost depending on usage.
GEMINI_API_KEY=
